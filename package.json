{
  "name": "convospan-intel",
  "version": "1.0.0",
  "description": "Robust B2B Web Scraper with Compliance Sentinel",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "cross-env NETJANA_MODE=standalone node dist/server.js",
    "start:legacy": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "dev:covospan": "cross-env NETJANA_MODE=covospan tsx watch src/modes/covospan/index.ts",
    "dev:standalone": "cross-env NETJANA_MODE=standalone tsx watch src/modes/standalone/index.ts",
    "dev:scraper": "cross-env NETJANA_MODE=worker ROLE=worker tsx watch src/modes/worker/index.ts",
    "build:covospan": "cross-env NETJANA_MODE=covospan tsc",
    "build:standalone": "cross-env NETJANA_MODE=standalone tsc",
    "build:scraper": "cross-env NETJANA_MODE=worker tsc",
    "start:covospan": "cross-env NETJANA_MODE=covospan node dist/modes/covospan/index.js",
    "start:standalone": "cross-env NETJANA_MODE=standalone ROLE=api_only node dist/modes/standalone/index.js",
    "start:scraper": "cross-env NETJANA_MODE=worker ROLE=worker node dist/modes/worker/index.js",
    "build:full": "npm run build && npm run build --prefix client",
    "mcp": "node dist/mcp/index.js"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.3",
    "@langchain/community": "^1.1.24",
    "@langchain/core": "^1.1.35",
    "@langchain/google-genai": "^2.1.24",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.2.12",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sentry/node": "^10.48.0",
    "@sentry/profiling-node": "^10.48.0",
    "@types/node-cron": "^3.0.11",
    "@upstash/redis": "^1.38.0",
    "axios": "^1.6.2",
    "axios-retry": "^3.8.0",
    "bullmq": "^5.71.0",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.2.3",
    "double-metaphone": "^2.0.1",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.3.2",
    "geoip-lite": "^1.4.10",
    "helmet": "^7.2.0",
    "ioredis": "^5.3.2",
    "ip": "^2.0.1",
    "langchain": "^1.2.36",
    "lucide-react": "^0.563.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "pg": "^8.20.0",
    "pg-format": "^1.0.4",
    "playwright": "^1.58.1",
    "prom-client": "^15.1.3",
    "robots-txt-parser": "*",
    "snoowrap": "^1.16.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "svix": "^1.89.0",
    "tailwind-merge": "^3.4.0",
    "uuid": "^9.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/express-rate-limit": "^6.0.0",
    "@types/ip": "^1.1.3",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^7.0.11",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.18.0",
    "@types/pg-format": "^1.0.5",
    "@types/uuid": "^9.0.7",
    "autoprefixer": "^10.4.23",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.60.0"
  }
}
