# ConvoSpan Intel production environment
# Copy to the production secret store. Do not commit real values.

NODE_ENV=production
PORT=3000
SERVE_FRONTEND=true
NETJANA_MODE=standalone

# Public URLs
PUBLIC_APP_URL=https://your-domain.com
ALLOWED_ORIGINS=https://your-domain.com,https://dashboard.your-domain.com

# Infrastructure
DATABASE_URL=postgres://user:password@hostname:5432/dbname?sslmode=require
REDIS_URL=rediss://:password@hostname:6379
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace_me

# Authentication
CLERK_SECRET_KEY=sk_live_replace_me
CLERK_WEBHOOK_SECRET=whsec_replace_me
VITE_CLERK_PUBLISHABLE_KEY=pk_live_replace_me

# AI provider
GOOGLE_API_KEY=replace_me
OPENAI_API_KEY=
OLLAMA_HOST=

# Required security
HMAC_SECRET=replace_with_32_plus_random_bytes
NETJANA_HMAC_SECRET=replace_with_different_32_plus_random_bytes
NETJANA_PULL_API_KEY=replace_with_random_pull_key
ALLOWED_INGEST_IPS=replace_with_source_ip_or_cidr
ENFORCE_INGEST_AUTH=true

# ConvoSpan integration
CONVOSPAN_WEBHOOK_URL=https://<CONVOSPAN_API_HOST>/webhooks/netjana-intel
CONVOSPAN_API_KEY=replace_me
BRAIN_WEBHOOK_URL=
CONVOSPAN_EDGE_WEBHOOK_URL=

# Outreach
OUTREACH_DEFAULT_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ConvoSpan Intel <noreply@your-domain.com>"
WABA_TOKEN=
WABA_PHONE_NUMBER_ID=
LINKEDIN_TOKEN=
LINKEDIN_URN=

# Tender / registry feeds
GEM_XML_FEED_URL=https://gem.gov.in/rss_feed
SANDBOX_API_KEY=
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# Monitoring
SENTRY_DSN=
VITE_SENTRY_DSN=
SLACK_WEBHOOK_URL=
PAGERDUTY_WEBHOOK_URL=
REGION_ID=GLOBAL_NODE_01

# Billing
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Feature flags
ENABLE_TURBOQUANT=true
DLQ_RETRY_LIMIT=3
