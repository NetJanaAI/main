# NetJana Sovereign Alpha — Production Environment Configuration
# Copy this file to .env on your production server

# --- Core Server ---
NODE_ENV=production
PORT=3000
SERVE_FRONTEND=true
ALLOWED_ORIGINS=https://your-domain.com,https://dashboard.your-domain.com
HMAC_SECRET=your_long_random_secure_hmac_secret_here

# --- Authentication (Clerk) ---
# USE PRODUCTION KEYS FROM clerk.com
CLERK_SECRET_KEY=sk_prod_...
CLERK_PUBLISHABLE_KEY=pk_prod_...

# --- AI Intelligence Layer ---
GOOGLE_API_KEY=your_production_google_gemini_pro_key

# --- Regional Connectivity & Infrastructure ---
# DATABASE_URL for SaaS Postgres (e.g. Neon, Supabase, Azure Postgres)
DATABASE_URL=postgres://user:password@hostname:5432/dbname?sslmode=require

# UPSTASH_REDIS_REST_URL (Required for Spend Guard & Rate Limiting)
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# REDIS_URL for BullMQ Background Jobs
REDIS_URL=rediss://:password@hostname:6379

# --- High-Frequency Proxy Mesh ---
# Residential proxy connection string (e.g. Bright Data)
PROXY_URL=http://user:pass@proxy-gate.com:22225
PROXY_USERNAME=...
PROXY_PASSWORD=...

# --- Market & Region Metadata ---
REGION_ID=GLOBAL_NODE_01
NETJANA_MODE=standalone

# --- ConvoSpan Intel Integration ---
# URL of the ConvoSpan webhook receiver. Do NOT change ConvoSpan paths.
CONVOSPAN_WEBHOOK_URL=https://<CONVOSPAN_API_HOST>/webhooks/netjana-intel
# API key issued by ConvoSpan (sent as x-api-key on outbound webhook pushes).
CONVOSPAN_API_KEY=
# HMAC secret shared with ConvoSpan. Signs outbound push payloads as:
#   HMAC-SHA256( "${timestamp}.${nonce}.${rawBody}" )
# MUST differ from HMAC_SECRET (which guards INBOUND /api/ingest/* calls).
NETJANA_HMAC_SECRET=your_long_random_outbound_hmac_secret_here
# API key NetJana issues to ConvoSpan for pull requests:
#   GET /v1/intel/leads/{lead_id}
NETJANA_PULL_API_KEY=your_long_random_pull_api_key_here
