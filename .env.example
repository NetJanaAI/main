PORT=3000
DATABASE_URL=postgresql://postgres:password@localhost:5432/b2b_scraper
REDIS_URL=redis://localhost:6379

# ─── AI Providers ────────────────────────────────────────────────────────────
# DEMO_MODE: If BOTH keys below are blank, the app runs in DEMO_MODE.
# All LLM calls return realistic structured mock data — the full pipeline
# (Gate → Qualify → Write → Outreach) executes without spending any API credits.
# Set GOOGLE_API_KEY to switch to live Gemini inference.
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Local Inference Alternative (Ollama). Overrides DEMO_MODE if set.
# OLLAMA_HOST=http://localhost:11434

# ─── Security ─────────────────────────────────────────────────────────────────
# HMAC_SECRET: Signs ingest payloads. Enforcement rules:
#   - Dev mode (NODE_ENV != production): any value or blank = local bypass allowed.
#   - Production: MUST be set to a strong secret. If left as the dev fallback
#     below, ALL ingest requests will be rejected with HTTP 503.
#   - When a real secret is set, every POST to /api/ingest/* MUST include the
#     x-source-signature header (HMAC-SHA256 of the JSON body).
HMAC_SECRET=dev-safety-fallback-do-not-use-in-prod

CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
VITE_CLERK_PUBLISHABLE_KEY=

# ─── Infrastructure ───────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173
# Comma-separated IPs allowed to POST to /api/ingest/*. Localhost always passes.
ALLOWED_INGEST_IPS=127.0.0.1

ENABLE_TURBOQUANT=true

# ─── ConvoSpan Intel Integration ─────────────────────────────────────────────
# URL of the ConvoSpan webhook receiver (DO NOT change ConvoSpan paths).
CONVOSPAN_WEBHOOK_URL=https://<CONVOSPAN_API_HOST>/webhooks/netjana-intel
# API key issued by ConvoSpan — sent as x-api-key on outbound pushes.
CONVOSPAN_API_KEY=
# HMAC secret shared with ConvoSpan to sign outbound webhook payloads.
# Signing input: "${timestamp}.${nonce}.${rawBody}"
# NOTE: This is the OUTBOUND signing secret. Do NOT confuse with HMAC_SECRET
# (which is the INBOUND secret for /api/ingest/* verification).
NETJANA_HMAC_SECRET=
# API key that NetJana issues to ConvoSpan for the pull endpoint:
# GET /v1/intel/leads/{lead_id}
NETJANA_PULL_API_KEY=

# ─── Outreach Configuration ──────────────────────────────────────────────────
# Default recipient for outreach emails (required for EMAIL channel dispatch)
OUTREACH_DEFAULT_EMAIL=
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ConvoSpan Sentinel" <noreply@convospan.com>

# ─── Commercialization ────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Operational Monitoring & Alerting ───────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/HERE
DLQ_RETRY_LIMIT=0
PAGERDUTY_WEBHOOK_URL=
