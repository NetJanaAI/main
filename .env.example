# ConvoSpan Intel local development environment
# Copy to .env for local Docker development. Do not commit .env.

NODE_ENV=development
PORT=3001
SERVE_FRONTEND=false
NETJANA_MODE=standalone

# Local infrastructure
DATABASE_URL=postgresql://postgres:password@localhost:5432/b2b_scraper
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Frontend
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VITE_CLERK_PUBLISHABLE_KEY=
VITE_SENTRY_DSN=

# AI providers
# If GOOGLE_API_KEY and OLLAMA_HOST are both blank in development, the app uses
# local demo fallback responses so the full pipeline can be exercised without spend.
GOOGLE_API_KEY=
OPENAI_API_KEY=
OLLAMA_HOST=

# Auth
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Security
# Development may use the fallback value below. Production must set a strong value.
HMAC_SECRET=dev-safety-fallback-do-not-use-in-prod
ALLOWED_INGEST_IPS=127.0.0.1,::1
ENFORCE_INGEST_AUTH=false

# ConvoSpan integration
CONVOSPAN_WEBHOOK_URL=https://<CONVOSPAN_API_HOST>/webhooks/netjana-intel
CONVOSPAN_API_KEY=
NETJANA_HMAC_SECRET=
NETJANA_PULL_API_KEY=
BRAIN_WEBHOOK_URL=
CONVOSPAN_EDGE_WEBHOOK_URL=

# Outreach
OUTREACH_DEFAULT_EMAIL=
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ConvoSpan Intel <noreply@convospan.com>"
WABA_TOKEN=
WABA_PHONE_NUMBER_ID=
LINKEDIN_TOKEN=
LINKEDIN_URN=

# Tender / registry feeds
GEM_XML_FEED_URL=https://gem.gov.in/rss_feed
SANDBOX_API_KEY=

# Monitoring
SENTRY_DSN=
SLACK_WEBHOOK_URL=
PAGERDUTY_WEBHOOK_URL=

# Billing
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Feature flags
ENABLE_TURBOQUANT=true
DLQ_RETRY_LIMIT=0
